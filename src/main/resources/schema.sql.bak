-- Drop tables if they exist to ensure a clean slate on startup
DROP TABLE IF EXISTS payments, tickets, schedules, seats, users, trains, app_details;

-- Table for Users
CREATE TABLE users (
    id VARCHAR(50) PRIMARY KEY,
    email VARCHAR(100) UNIQUE NOT NULL,
    password VARCHAR(100) NOT NULL,
    name VARCHAR(100) NOT NULL,
    mobile VARCHAR(15),
    payment_info VARCHAR(255),
    role VARCHAR(20) NOT NULL DEFAULT 'USER' -- e.g., 'USER', 'ADMIN'
);

-- Table for Trains
CREATE TABLE trains (
    id VARCHAR(50) PRIMARY KEY,
    name VARCHAR(100) NOT NULL,
    source VARCHAR(100) NOT NULL,
    destination VARCHAR(100) NOT NULL
);

-- Table for Seats Management
CREATE TABLE seats (
    train_id VARCHAR(50),
    class_type VARCHAR(50), -- Sleeper, 3A, 2A, 1A
    total_seats INT,
    available_seats INT,
    PRIMARY KEY (train_id, class_type),
    FOREIGN KEY (train_id) REFERENCES trains(id) ON DELETE CASCADE
);

-- Table for Schedule Management
CREATE TABLE schedules (
    id INT AUTO_INCREMENT PRIMARY KEY,
    train_id VARCHAR(50),
    departure_time VARCHAR(50),
    arrival_time VARCHAR(50),
    travel_date DATE,
    FOREIGN KEY (train_id) REFERENCES trains(id) ON DELETE CASCADE
);

-- Table for Tickets
CREATE TABLE tickets (
    ticket_id VARCHAR(100) PRIMARY KEY,
    user_id VARCHAR(50),
    train_id VARCHAR(50),
    booking_date VARCHAR(50),
    travel_class VARCHAR(50),
    price DOUBLE,
    status VARCHAR(20) DEFAULT 'BOOKED', -- BOOKED, CANCELLED
    FOREIGN KEY (user_id) REFERENCES users(id),
    FOREIGN KEY (train_id) REFERENCES trains(id)
);

-- Table for Admin Notifications/Offers/Customer Service Details
CREATE TABLE app_details (
    detail_key VARCHAR(50) PRIMARY KEY,
    detail_value TEXT
);